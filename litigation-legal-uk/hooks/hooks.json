{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/plugins/litigation-legal-uk/scripts/hook-announce.sh start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/plugins/litigation-legal-uk/scripts/hook-announce.sh prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/plugins/litigation-legal-uk/scripts/hook-announce.sh pre-tool"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "developer__shell|developer__text_editor",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.agents/plugins/litigation-legal-uk/scripts/hook-announce.sh post-tool"
          }
        ]
      }
    ]
  }
}
